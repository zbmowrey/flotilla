# Flotilla compose env. Copy to .env and fill in. .env is gitignored.

# --- Host paths ---
# Base directory holding per-service config bind mounts (e.g. ${FLOTILLA_DIR}/sonarr -> /config)
FLOTILLA_DIR=/path/to/flotilla/.flotilla

# --- Timezone ---
TZ=America/New_York

# --- Port assignments ---
SABNZBD_UI_PORT=9000
TRANSMISSION_MOVIES_UI_PORT=9001
TRANSMISSION_TV_UI_PORT=9002
PROWLARR_UI_PORT=9003
OVERSEERR_UI_PORT=9004
RADARR_UI_PORT=9005
SONARR_UI_PORT=9006
LIDARR_UI_PORT=9007
BAZARR_UI_PORT=9008
LAZY_LIBRARIAN_UI_PORT=9009
READARR_UI_PORT=8787
WHISPARR_UI_PORT=6969
AUDIOBOOKSHELF_UI_PORT=13378
MINIO_API_PORT=9500
MINIO_CONSOLE_PORT=9501
QBITTORRENT_UI_PORT=9010
GLUETUN_CONTROL_PORT=9011
NAVIDROME_UI_PORT=9012

# --- SABnzbd download dirs ---
SABNZBD_TEMP_DIR=/path/to/downloads/sabnzbd/temp
SABNZBD_COMPLETE_DIR=/path/to/downloads/sabnzbd/complete

# --- Transmission TV (currently inactive in compose) ---
TRANSMISSION_TV_TEMP_DIR=/path/to/downloads/transmission_tv/temp
TRANSMISSION_TV_COMPLETE_DIR=/path/to/downloads/transmission_tv/complete
TRANSMISSION_TV_WATCH_DIR=/path/to/downloads/transmission_tv/watch

# --- Transmission Movies (still referenced by prowlarr/radarr/lidarr/bazarr mounts) ---
TRANSMISSION_MOVIES_TEMP_DIR=/path/to/downloads/transmission_movies/temp
TRANSMISSION_MOVIES_COMPLETE_DIR=/path/to/downloads/transmission_movies/complete
TRANSMISSION_MOVIES_WATCH_DIR=/path/to/downloads/transmission_movies/watch

# --- PIA OpenVPN (used by the gluetun container) ---
PIA_USER=
PIA_PASS=
# PIA region — must be a port-forwarding supported region.
PIA_REGION=CA Toronto

# --- qBittorrent ---
# linuxserver/qbittorrent defaults to admin / adminadmin. Change in the WebUI,
# then update QBITTORRENT_PASSWORD so the port-sync sidecar can authenticate.
QBITTORRENT_USERNAME=admin
QBITTORRENT_PASSWORD=adminadmin

# --- Watchtower schedule (Quartz 6-field cron) ---
WATCHTOWER_SCHEDULE=0 0 4 * * *

# --- Final media library locations ---
ADULT_DIR=/path/to/media/adult
AUDIOBOOKS_DIR=/path/to/media/audiobooks
BOOKS_DIR=/path/to/media/ebooks
COMICS_DIR=/path/to/media/comics
MOVIES_DIR=/path/to/media/movies
MUSIC_DIR=/path/to/media/music
PODCASTS_DIR=/path/to/media/podcasts
TV_DIR=/path/to/media/tv

# --- MinIO ---
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
MINIO_DEFAULT_BUCKETS=default
MINIO_DATA_DIR=/path/to/minio/data

# --- DuckDNS (if you re-add the duckdns container) ---
DUCKDNS_TOKEN=
DUCKDNS_SUBDOMAINS=

# --- Portainer API (used by scripts/portainer_inventory.py and future redeploy automation) ---
PORTAINER_URL=http://192.168.0.10:19900
PORTAINER_ACCESS_TOKEN=
